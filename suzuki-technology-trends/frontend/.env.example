# Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# ======================
# LangGraph Platform
# ======================
# LangGraph Platform server URL
LANGGRAPH_PLATFORM_URL=http://localhost:8123

# LangGraph graph ID to use (must match backend/langgraph.json)
LANGGRAPH_GRAPH_ID=drawer-ai

# LangGraph Platform API key (required for authentication)
LANGGRAPH_API_KEY=

# ======================
# ISP (Interactive Search Platform)
# ======================
# ISP server URL
ISP_URL=http://localhost:50080

# ISP index name prefix
# The actual index name is constructed as: {ISP_INDEX_NAME}_{tenant_id}
# tenant_id is extracted from the internal token
ISP_INDEX_NAME=suzuki-technology-trends

# ======================
# Authentication
# ======================
# Internal token for development (server-side only)
# In production, tokens are extracted from request headers
INTERNAL_TOKEN=

# Cloudflare Access credentials (for production deployment)
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
