# Google Application Credentials（サービスアカウントJSONファイルのパス）
# プロジェクトルートからの相対パスまたは絶対パスを指定
GOOGLE_APPLICATION_CREDENTIALS=./caddi-cp-it-gemini-internal-2e058b90ed99.json

# セキュリティキー（本番環境では必ず変更）
SECRET_KEY=change-me-in-production-please-use-random-string

# LLMモデル設定（オプション）
LLM_MODEL_NAME_FLASH=gemini-2.5-flash
EMBEDDING_MODEL=models/embedding-001

# ログレベル（オプション）
LOG_LEVEL=INFO

# データベース設定（Docker Compose使用時は自動設定）
# DATABASE_URL=postgresql://drawerai_user:drawerai_password@db:5432/drawerai

# Redis設定（Docker Compose使用時は自動設定）
# REDIS_URL=redis://redis:6379/0
