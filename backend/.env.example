# To separate your traces from other application
LANGSMITH_PROJECT=new-agent

# Add API keys for connecting to LLM providers, data sources, and other integrations here

# =============================================================================
# ISP (Interactive Search Platform) Configuration
# =============================================================================
# ISP server URL (default: http://localhost:50080)
# ISP_URL=http://localhost:50080

# ISP authentication token (optional, for production environments)
# ISP_AUTH_TOKEN=your-auth-token

# Default ISP index name (overrides config file setting)
# ISP_INDEX=drbfm-assist-defects_a7753ab8-12e3-44f0-9ae6-9e85637b890e

# =============================================================================
# Cloudflare Access (for self-hosted Langsmith)
# =============================================================================
# Cloudflare Access credentials for Langsmith authentication
# CF_ACCESS_CLIENT_ID=your-client-id
# CF_ACCESS_CLIENT_SECRET=your-client-secret
