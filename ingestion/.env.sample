# 必須: environment(dev, stg, prod)
ENVIRONMENT=dev

# 必須: Tenant ID
TENANT_ID=12345678-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 必須: OAuth2 Client Credentials (MSQP用)
MSQP_CLIENT_ID=agent-ingest-12345678
MSQP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxx

# M2M Token Issuer credentials (ISP認証用) https://backstage.caddi.io/docs/default/component/m2m-token-issuer
M2M_INTERNAL_TOKEN_CLIENT_ID=agent-ingest-12345678
M2M_INTERNAL_TOKEN_CLIENT_SECRET=your-client-secret

# Optional: 静的な Internal Token (テスト/デバッグ用)　設定すると M2M Token Issuer API を呼ばずにこのトークンを使用します
# M2M_INTERNAL_TOKEN=e

# Optional: settings
QUERY_FILE_LIMIT=2

LOGURU_LEVEL=INFO



# Optional: Local開発モードは true に設定
# LOCAL_MODE=true の場合、以下のデフォルト値が自動的に使用されます:
#   - HTTPS_PROXY: socks5h://localhost:1080 (MSQP用)
#   - ISP_API_URL: http://localhost:3000 (kubectl port-forward経由)
LOCAL_MODE=false
